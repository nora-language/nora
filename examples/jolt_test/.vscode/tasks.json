{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Nora (Debug) (Linux)",
            "type": "shell",
            "command": "../../nora_real",
            "args": [
                "build",
                "-g",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build Nora (Debug) (Windows)",
            "type": "shell",
            "command": "../../nora.exe",
            "args": [
                "build",
                "-g",
                "-debug-memory",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
